---
layout: null
---
{% assign items = site.epigraphy %}[
{% for rec in items %}
{
  "title": {{ rec.title | jsonify }},
  "url": {{ rec.url | jsonify }},
  "material": {{ rec.material | jsonify }},
  "provenance": {{ rec.provenance | jsonify }},
  "findspot": {{ rec.findspot | jsonify }},
  "chronology": {{ rec.chronology | jsonify }},
  "language": {{ rec.language | jsonify }},
  "type": {{ rec.type | jsonify }},
  "text": {{ rec.content | strip_newlines | jsonify }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]